# AEGIS Backend Configuration
# ----------------------------

# --- GenAI Models ---
# gemini_flash (recommended), gemini_pro
DEFAULT_PLANNING_MODEL=gemini_flash
DEFAULT_CODEGEN_MODEL=gemini_flash

# --- AI Studio API Key ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Persistence Backend ---
# Options: supabase, local
STORE_BACKEND=supabase

# --- Supabase Admin configuration (Use SECRET Service Role Key) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# --- Telegram Bot Configuration ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=Aegis_telebot
TELEGRAM_WEBHOOK_URL=https://your-backend-api.render.com/api/telegram/webhook

# --- Algorand Testnet ---
RPC_URL=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
# For AVM Logic, we use Algorand Testnet constants in config.py
# but these are helpful for SDK overrides.

# --- Executor (Backend Node Identity) ---
# Your automation executor private key (mnemonic or hex)
EXECUTOR_PRIVATE_KEY=your_private_key_here

# --- CORS ---
# Local: http://localhost:5173
# Prod: https://your-frontend.vercel.app
CLIENT_ORIGIN=http://localhost:5173
